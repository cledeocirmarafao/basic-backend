generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

// snake case = first_name
// camel case = firstName

// in sql = create table users
// in prisma = model User
model User {
  id        Int       @id @default(autoincrement())
  firstName String    @map("first_name")
  lastName  String    @map("last_name")
  email     String    @unique
  password  String
  phone     String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  adresses  Address[]

  @@map("users")
}

model Address {
  id           Int    @id @default(autoincrement())
  street       String
  neighborhood String
  zipCode      String @map("zip_code")
  userId       Int    @map("user_id")
  user         User   @relation(fields: [userId], references: [id])

  @@map("adresses")
}

// Vou criar uma tabela de produtos pra exemplificar a necessidade de executar o generaete sempre que eu fizer uma migration, pra que o client seja atualizado com as novas mudanças do schema.prisma

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  price       Decimal
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  stock      Stock[]

  @@map("products")
}

model Stock {
  id        Int     @id @default(autoincrement())
  productId Int     @map("product_id")
  quantity  Int
  product   Product @relation(fields: [productId], references: [id])

  @@map("stocks")
}
